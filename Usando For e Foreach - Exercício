import 'dart:io';
class GradeManager {
  final List<double> _grades = [];
  void addGrade(double grade) {
    if (grade < 0 || grade > 10) {
      throw ArgumentError('Nota d.');
    }
    _grades.add(grade);
  }
  double calculateAverage() {
    if (_grades.isEmpty) {
      return 0.0;
    }
    final sum = _grades.reduce((a, b) => a + b);
    return sum / _grades.length;
  }
  int get count => _grades.length;
  List<double> get grades => List.unmodifiable(_grades);
}
void main() {
  final manager = GradeManager();
  print('--- Sistema de Cálculo de Média da Turma ---');
  print('Digite as notas dos alunos (digite "fim" para encerrar):');
  while (true) {
    stdout.write('Nota ${manager.count + 1}: ');
    final input = stdin.readLineSync()?.trim().toLowerCase();
    if (input == 'fim' || input == null) {
      break;
    }
    try {
      final grade = double.parse(input);
      manager.addGrade(grade);
    } catch (e) {
      print('Erro: Por favor, digite um número válido entre 0 e 10.');
    }
  }
  if (manager.count > 0) {
    final average = manager.calculateAverage();
    print('\n--- Resultados ---');
    print('Total de alunos: ${manager.count}');
    print('Média da turma: ${average.toStringAsFixed(2)}');
    if (average >= 7.0) {
      print('Status: Turma com bom desempenho.');
    } else {
      print('Status: Atenção ao desempenho da turma.');
    }
  } else {
    print('\nNenhuma nota foi inserida.');
  }
}


