INDEX.JS:

const express = require('express');
const exphbs = require('express-handlebars');
const mysql = require('mysql2');

const app = express();

// Configuração para ler dados do corpo da requisição (POST)
app.use(express.urlencoded({ extended: true }));
app.use(express.json());

// Configuração do Handlebars
app.engine('handlebars', exphbs.engine());
app.set('view engine', 'handlebars');
app.use(express.static('public')); // Para carregar o style.css

// Cria a conexão com o MySQL
const conn = mysql.createConnection({
    host: 'localhost',
    user: 'root', // substitua pelo seu usuário
    password: '',     // substitua pela sua senha
    database: 'teste34'
});

conn.connect(function (err) {
    if (err) {
        console.log('Erro ao conectar ao MySQL:', err);
    } else {
        console.log('Node está conversando com o MySQL!');
    }
});

// Renderiza o formulário (home.handlebars)
app.get('/', (req, res) => {
    res.render('home');
});

app.post('/teste/insertteste', (req, res) => {
    const { nome, email } = req.body;

    const sql = `INSERT INTO users (nome, email) VALUES (?, ?)`;
    const data = [nome, email];

    conn.query(sql, data, function (err) {
        if (err) {
            console.log(err);
            return;
        }
        res.redirect('/teste'); // Redireciona para a listagem após inserir
    });
});

app.get('/teste', (req, res) => {
    const sql = "SELECT * FROM users";

    conn.query(sql, function (err, data) {
        if (err) {
            console.log(err);
            return;
        }
        
        // Renderiza teste.handlebars enviando os dados do banco
        res.render('teste', { teste: data }); 
    });
});

app.listen(3000, () => {
    console.log('Servidor rodando na porta 3000');
});


