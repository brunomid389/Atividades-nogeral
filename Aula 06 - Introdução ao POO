class Produto {
  String nome;
  double preco;
  int quantidade
  Produto(this.nome, this.preco, this.quantidade);
  void mostrarDados() {
    print("Produto: $nome | Preço: R\$ $preco | Qtd: $quantidade");
  }
  void calcularTotal() {
    double total = preco * quantidade;
    print("Total em estoque de $nome: R\$ $total");
  }
}
void main() {
  Produto p1 = Produto("Notebook", 3500.0, 5);
  Produto p2 = Produto("Mouse", 80.0, 20);
  Produto p3 = Produto("Teclado", 250.0, 12);
  p1.mostrarDados();
  p1.calcularTotal();
  p2.mostrarDados();
  p2.calcularTotal();
  p3.mostrarDados();
  p3.calcularTotal();
}


